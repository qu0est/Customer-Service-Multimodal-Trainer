# Copy this file to .env and fill in your credentials

# Your Gemini API key from Google AI Studio (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# An arbitrary API key for the FastAPI backend (can be anything, e.g. "my-api-key")
USER_API_KEY=my-api-key

# The Gemini model to use for moderation agents
DEFAULT_GOOGLE_MODEL=gemini-2.5-flash-lite

# Model used as judge in evaluations
EVAL_JUDGE_MODEL=gemini-2.5-flash-lite

# Number of times to repeat each eval test case (1 = quick, 5-10 = reliable)
EVAL_NUM_REPEATS=1
